<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>{{ person.name }} | Портфолио</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Space+Grotesk:wght@600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
</head>
<body>
  <div class="container">
    <div class="profile">
      <img src="{{ url_for('static', filename=person.avatar if person.avatar else 'placeholder.png') }}" alt="Аватар" class="avatar">

      <h1>{{ person.name }}</h1>
      <p>{{ person.bio }}</p>
      {% if person.telegram %}
      <div style="margin-top: 10px;">
        <a href="https://t.me/{{ person.telegram }}" target="_blank" title="Открыть Telegram">
          <span class="badge">✈️ Telegram: @{{ person.telegram }}</span>
        </a>
      </div>
      {% endif %}
    </div>

    <div class="info">
      <h2>Навыки</h2>
      <ul class="skills">
        {% for skill in skills %}
          <li>{{ skill }}</li>
        {% endfor %}
      </ul>

      <h2>Инструменты</h2>
      <ul>
        {% for tech, icon in tool_icons.items( ) %}
          {% if tech.lower() in skills %}
            <li class="badge">{{ icon }} {{ tech }}</li>
          {% endif %}
        {% endfor %}
      </ul>
      <h2>Проекты с GitHub</h2>
      <div class="projects">
        {% if projects %}
          {% for project in projects %}
          <div class="project-box">
            <h3>{{ project.title }}</h3>
            <p>{{ project.description }}</p>
            <a href="{{ project.link }}" target="_blank">Перейти →</a>
          </div>
          {% endfor %}
        {% else %}
          <p>Проекты загружаются или не найдены...</p>
        {% endif %}
      </div>

      <div style="margin-top: 30px;">
          <a href="{{ url_for('index') }}" style="text-decoration: none; color: #666;">← Ко всем портфолио</a>
      </div>
    </div>
  </div>
</body>
</html>
